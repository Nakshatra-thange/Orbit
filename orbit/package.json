    "@opentelemetry/exporter-jaeger": "^2.8.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^4.1.1",
    "ioredis": "^5.11.1",
