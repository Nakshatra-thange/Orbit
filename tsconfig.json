{
    "compilerOptions": {
      "target": "ES2020",
      "module": "commonjs",
      "lib": ["ES2020"],
      "types": ["node"],
      "outDir": "./dist",
      "rootDir": "./",
      "ignoreDeprecations": "6.0",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "declaration": true,
      "sourceMap": true,
      "resolveJsonModule": true,
      "baseUrl": ".",
      "paths": {
        "@shared/*": ["shared/*"]
      }
    },
    "include": ["gateway/src/**/*", "services/**/*.ts", "shared/**/*","scripts/**/*.ts"],
    "exclude": ["node_modules", "dist", "dashboard"]
  }